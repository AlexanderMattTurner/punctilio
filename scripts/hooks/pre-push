#!/bin/bash

set -e

echo "🔍 Running pre-push checks..."

# Run tests
echo "🧪 Running tests..."
npm test

if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Push aborted."
  exit 1
fi

echo "✅ All tests passed."

# Check if we're pushing to main/master
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [[ "$BRANCH" != "main" && "$BRANCH" != "master" ]]; then
  echo "ℹ️  Not on main branch, skipping version bump and publish."
  exit 0
fi

# Check if there are any commits to push
LOCAL=$(git rev-parse @)
REMOTE=$(git rev-parse @{u} 2>/dev/null || echo "")

if [ "$LOCAL" = "$REMOTE" ]; then
  echo "ℹ️  No new commits to push."
  exit 0
fi

# Check if package.json has been modified in this push
MODIFIED_FILES=$(git diff --name-only @{u}..HEAD 2>/dev/null || git diff --name-only HEAD~1..HEAD)

# Only bump version if package.json wasn't already modified (to avoid double-bumping)
if echo "$MODIFIED_FILES" | grep -q "package.json"; then
  echo "ℹ️  package.json already modified in this push, skipping auto-version bump."
else
  echo "📦 Auto-versioning package..."
  bash scripts/version-bump.sh
  
  if [ $? -ne 0 ]; then
    echo "⚠️  Version bump failed, continuing without version change."
  fi
fi

# Build the package
echo "🔨 Building package..."
npm run build

if [ $? -ne 0 ]; then
  echo "❌ Build failed. Push aborted."
  exit 1
fi

# Publish to npm
echo "📤 Publishing to npm..."
npm publish --access public

if [ $? -ne 0 ]; then
  echo "❌ Publish failed. Push aborted."
  exit 1
fi

echo "✅ Package published successfully!"
echo "🚀 Proceeding with git push..."

exit 0
